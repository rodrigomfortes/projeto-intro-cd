    "feat = [\n",
    "    \"taxa_entrada\",\n",
    "    \"perc_provisorios\",\n",
    "    \"indice_precariedade_estrutura\",\n",
    "    \"perc_18_29\",\n",
    "    \"perc_parda_preta\",\n",
    "]\n",
    "feat = [c for c in feat if c in df.columns]\n",
    "reg_data = df[feat + [\"taxa_superlotacao_real\"]].apply(pd.to_numeric, errors=\"coerce\").dropna()\n",
    "display(Markdown(f\"**Amostra da regressão:** *n* = {len(reg_data)} estabelecimentos (lista completa nas variáveis).\"))\n",
    "\n",
    "y = reg_data[\"taxa_superlotacao_real\"]\n",
    "X_raw = reg_data[feat]\n",
    "\n",
    "if HAS_SM:\n",
    "    X = sm.add_constant(X_raw)\n",
    "    ols = sm.OLS(y, X).fit()\n",
    "    display(Markdown(\"### Tabela de coeficientes (statsmodels OLS)\"))\n",
    "    tab = pd.DataFrame(\n",
    "        {\n",
    "            \"coef\": ols.params,\n",
    "            \"erro_padrao\": ols.bse,\n",
    "            \"t\": ols.tvalues,\n",
    "            \"p_valor\": ols.pvalues,\n",
    "            \"IC_2.5%\": ols.conf_int()[0],\n",
    "            \"IC_97.5%\": ols.conf_int()[1],\n",
    "        }\n",
    "    )\n",
    "    display(tab.round(4))\n",
    "    display(Markdown(f\"**R² ajustado:** {ols.rsquared_adj:.4f} · **AIC:** {ols.aic:.1f}\"))\n",
    "    y_hat = pd.Series(ols.fittedvalues, index=y.index)\n",
    "    resid = pd.Series(ols.resid, index=y.index)\n",
    "    coef_plot = tab[\"coef\"].drop(\"const\", errors=\"ignore\")\n",
    "else:\n",
    "    lr = LinearRegression()\n",
    "    lr.fit(X_raw, y)\n",
    "    y_hat = pd.Series(lr.predict(X_raw), index=y.index)\n",
    "    resid = y - y_hat\n",
    "    display(Markdown(\"### Coeficientes (sklearn — sem IC analítico)\"))\n",
    "    coef_tab = pd.DataFrame({\"variavel\": feat, \"coef\": lr.coef_})\n",
    "    display(coef_tab.round(6))\n",
    "    display(Markdown(f\"**Intercepto:** {lr.intercept_:.6f}\"))\n",
    "    r2 = r2_score(y, y_hat)\n",
    "    rmse = float(np.sqrt(mean_squared_error(y, y_hat)))\n",
    "    display(Markdown(f\"**R²:** {r2:.4f} · **RMSE:** {rmse:.4f}\"))\n",
    "    coef_plot = pd.Series(lr.coef_, index=feat)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(6, 4))\n",
    "ax.barh(coef_plot.index.astype(str), coef_plot.values, color=\"steelblue\")\n",
    "ax.axvline(0, color=\"black\", linewidth=0.8)\n",
    "ax.set_title(\"Pergunta 5 — Coeficientes da regressão (direção e magnitude)\")\n",
    "ax.set_xlabel(\"Coeficiente\")\n",
    "fig.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(5.5, 5.5))\n",
    "ax.scatter(y, y_hat, alpha=0.4, s=20, color=\"darkgreen\")\n",
    "m = min(y.min(), y_hat.min())\n",
    "M = max(y.max(), y_hat.max())\n",
    "ax.plot([m, M], [m, M], \"r--\", label=\"y = ŷ\")\n",
    "ax.set_xlim(0, 1)\n",
    "ax.set_ylim(0, 1)\n,"
    "ax.set_xlabel(\"Taxa observada\")\n",
    "ax.set_ylabel(\"Taxa predita\")\n",
    "ax.set_title(\"Pergunta 5 — Ajuste: observado vs predito\")\n",
    "ax.legend()\n",
    "fig.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(6, 4))\n",
    "ax.hist(resid, bins=35, color=\"gray\", edgecolor=\"white\", alpha=0.9)\n",
    "ax.axvline(0, color=\"darkred\", linestyle=\"--\")\n",
    "ax.set_xlabel(\"Resíduo\")\n",
    "ax.set_ylabel(\"Frequência\")\n",
    "ax.set_title(\"Pergunta 5 — Distribuição dos resíduos\")\n",
    "fig.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Heatmap correlacional das variáveis do modelo (complemento visual)\n",
    "subc = reg_data.corr(method=\"pearson\")\n",
    "fig, ax = plt.subplots(figsize=(6, 5))\n",
    "im = ax.imshow(subc.values, cmap=\"RdBu_r\", vmin=-1, vmax=1)\n",
    "ax.set_xticks(range(len(subc.columns)))\n",
    "ax.set_yticks(range(len(subc.columns)))\n",
    "ax.set_xticklabels(subc.columns, rotation=55, ha=\"right\")\n",
    "ax.set_yticklabels(subc.columns)\n",
    "for i in range(len(subc)):\n",
    "    for j in range(len(subc)):\n",
    "        ax.text(j, i, f\"{subc.values[i, j]:.2f}\", ha=\"center\", va=\"center\", fontsize=8)\n",
    "fig.colorbar(im, ax=ax, fraction=0.046, pad=0.04)\n",
    "ax.set_title(\"Correlação de Pearson — variáveis da regressão\")\n",
    "fig.tight_layout()\n",
    "plt.show()\n"
   ]
