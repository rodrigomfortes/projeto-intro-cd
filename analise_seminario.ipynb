    "ax.set_xlabel(\"População total (escala log)\")\n",
    "ax.set_ylabel(\"Índice de precariedade estrutural\")\n",
    "ax.set_title(\"Pergunta 2 — População × precariedade (cor = superlotação)\")\n",
