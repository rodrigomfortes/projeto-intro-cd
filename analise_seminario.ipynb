   "source": [
    "for name, col in [\n",
    "    (\"Sem módulo de educação\", \"flag_sem_educacao\"),\n",
    "    (\"Sem módulo de saúde\", \"flag_sem_saude\"),\n",
    "    (\"Sem assistência jurídica (proxy)\", \"flag_sem_assistencia_juridica\"),\n",
    "]:\n",
    "    if col in df.columns:\n",
    "        s = pd.to_numeric(df[col], errors=\"coerce\")\n",
    "        n1 = int((s == 1).sum())\n",
    "        display(Markdown(f\"- **{name}:** {n1} estabelecimentos com flag = 1 (entre respostas válidas).\"))\n",
    "\n",
    "display(Markdown(\"**Cruzamento superlotação × ausência de educação:**\"))\n",
    "display(pd.crosstab(df[\"flag_superlotacao\"], df[\"flag_sem_educacao\"], dropna=False))\n",
    "\n",
    "stack = (\n",
    "    df.groupby([\"flag_superlotacao\", \"flag_sem_educacao\"], dropna=False)\n",
    "    .size()\n",
    "    .unstack(fill_value=0)\n",
    ")\n",
    "stack_pct = stack.div(stack.sum(axis=1), axis=0) * 100\n",
    "fig, ax = plt.subplots(figsize=(7, 4))\n",
    "stack_pct.T.plot(kind=\"bar\", stacked=True, ax=ax, color=[\"#4c72b0\", \"#dd8452\"])\n",
    "ax.set_xlabel(\"flag_sem_educacao\")\n",
    "ax.set_ylabel(\"% dentro do grupo de superlotação\")\n",
    "ax.set_title(\"Pergunta 2 — Superlotação × ausência de módulo de educação\")\n",
    "ax.legend(title=\"flag_superlotacao\", bbox_to_anchor=(1.02, 1))\n",
    "fig.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "subp = df.dropna(subset=[\"pop_total_final\", \"indice_precariedade_estrutura\"]).copy()\n",
    "fig, ax = plt.subplots(figsize=(7, 5))\n",
    "sc = ax.scatter(\n",
    "    subp[\"pop_total_final\"],\n",
    "    subp[\"indice_precariedade_estrutura\"],\n",
    "    c=subp[\"flag_superlotacao\"],\n",
    "    cmap=\"coolwarm\",\n",
    "    alpha=0.5,\n",
    "    s=22,\n",
    ")\n",
    "plt.colorbar(sc, ax=ax, label=\"Superlotação (0/1)\")\n",
