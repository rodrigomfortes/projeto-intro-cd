   "source": [
    "taxa = df[\"taxa_superlotacao_real\"].replace([np.inf, -np.inf], np.nan).dropna()\n",
    "pct_super = (df[\"flag_superlotacao\"] == 1).mean() * 100\n",
    "display(Markdown(f\"**Estabelecimentos com taxa > 1:** {pct_super:.1f}% da amostra.\"))\n",
    "\n",
    "fig, ax = plt.subplots()\n",
    "ax.hist(taxa, bins=40, color=\"steelblue\", edgecolor=\"white\", alpha=0.9)\n",
    "ax.axvline(1.0, color=\"darkred\", linestyle=\"--\", label=\"Referência: taxa = 1\")\n",
    "ax.set_xlabel(\"Taxa (população / capacidade)\")\n",
    "ax.set_ylabel(\"Frequência\")\n",
    "ax.set_title(\"Pergunta 1 — Distribuição da taxa de lotação por estabelecimento\")\n",
    "ax.legend()\n",
    "fig.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "uf_stats = (\n",
    "    df.groupby(\"uf\", observed=True)\n",
    "    .agg(\n",
    "        n=(\"uf\", \"size\"),\n",
    "        taxa_media=(\"taxa_superlotacao_real\", \"mean\"),\n",
    "        taxa_mediana=(\"taxa_superlotacao_real\", \"median\"),\n",
    "        pct_super=(\"flag_superlotacao\", \"mean\"),\n",
    "    )\n",
    "    .sort_values(\"taxa_mediana\", ascending=False)\n",
    ")\n",
    "display(Markdown(\"**Mediana e % superlotados por UF (top 10 por mediana):**\"))\n",
    "_ufs = uf_stats.head(10).copy()\n",
    "_ufs[\"pct_super\"] = _ufs[\"pct_super\"] * 100\n",
    "display(_ufs.round({\"taxa_media\": 3, \"taxa_mediana\": 3, \"pct_super\": 1, \"n\": 0}))\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, max(4, 0.25 * len(uf_stats))))\n",
    "y = np.arange(len(uf_stats))\n",
    "ax.barh(y, uf_stats[\"taxa_mediana\"].values, color=\"teal\", alpha=0.85)\n",
    "ax.set_yticks(y)\n",
    "ax.set_yticklabels(uf_stats.index)\n",
    "ax.invert_yaxis()\n",
    "ax.axvline(1.0, color=\"darkred\", linestyle=\"--\")\n",
    "ax.set_xlabel(\"Mediana da taxa (pop / capacidade)\")\n",
    "ax.set_title(\"Pergunta 1 — UFs ordenadas pela mediana da taxa de lotação\")\n",
    "fig.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "tipo_counts = df[\"tipo_estabelecimento\"].value_counts()\n",
    "tipos_ok = tipo_counts[tipo_counts >= 5].index\n",
    "sub = df[df[\"tipo_estabelecimento\"].isin(tipos_ok)]\n",
    "order = (\n",
    "    sub.groupby(\"tipo_estabelecimento\", observed=True)[\"taxa_superlotacao_real\"]\n",
    "    .median()\n",
    "    .sort_values(ascending=False)\n",
    "    .index.tolist()\n",
    ")\n",
    "fig, ax = plt.subplots(figsize=(9, 5))\n",
    "data_box = [sub.loc[sub[\"tipo_estabelecimento\"] == t, \"taxa_superlotacao_real\"].dropna() for t in order]\n",
    "ax.boxplot(data_box, labels=order, vert=True, showfliers=False)\n",
    "ax.axhline(1.0, color=\"darkred\", linestyle=\"--\")\n",
    "ax.set_ylabel(\"Taxa pop/capacidade\")\n",
    "ax.set_title(\"Pergunta 1 — Superlotação por tipo de estabelecimento (n ≥ 5)\")\n",
    "plt.xticks(rotation=55, ha=\"right\")\n",
    "fig.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "rank_units = df.nlargest(15, \"deficit_vagas\")[\n",
    "    [\"uf\", \"municipio\", \"tipo_estabelecimento\", \"pop_total_final\", \"capacidade_total_final\", \"deficit_vagas\", \"taxa_superlotacao_real\"]\n",
    "]\n",
    "display(Markdown(\"**Top 15 unidades por déficit absoluto (pop − capacidade):**\"))\n",
    "display(\n",
    "    rank_units.round(\n",
    "        {\n",
    "            \"pop_total_final\": 0,\n",
    "            \"capacidade_total_final\": 0,\n",
    "            \"deficit_vagas\": 0,\n",
    "            \"taxa_superlotacao_real\": 3,\n",
    "        }\n",
    "    )\n",
    ")\n"
   ]
