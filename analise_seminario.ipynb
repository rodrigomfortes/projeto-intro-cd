   "source": [
    "ent_sum = pd.to_numeric(df[\"mov_entradas_total\"], errors=\"coerce\").sum()\n",
    "alv_sum = pd.to_numeric(df[\"mov_alvaras_total\"], errors=\"coerce\").sum()\n",
    "display(Markdown(f\"**Soma nacional (estabelecimentos):** entradas = {ent_sum:,.0f} · alvarás = {alv_sum:,.0f}.\"))\n",
    "\n",
    "uf_flux = (\n",
    "    df.groupby(\"uf\", observed=True)\n",
    "    .agg(taxa_entrada_med=(\"taxa_entrada\", \"mean\"), taxa_saida_med=(\"taxa_saida\", \"mean\"))\n",
    "    .sort_values(\"taxa_entrada_med\", ascending=False)\n",
    ")\n",
    "display(Markdown(\"**UFs com maior taxa média de entrada (top 10):**\"))\n",
    "display(uf_flux.head(10).round(4))\n",
    "\n",
    "sub = df.dropna(subset=[\"taxa_entrada\", \"taxa_superlotacao_real\", \"perc_provisorios\"]).copy()\n",
    "fig, ax = plt.subplots(figsize=(7, 5))\n",
    "sc = ax.scatter(\n",
    "    sub[\"taxa_entrada\"],\n",
    "    sub[\"taxa_superlotacao_real\"],\n",
    "    c=sub[\"perc_provisorios\"],\n",
    "    cmap=\"viridis\",\n",
    "    alpha=0.55,\n",
    "    s=28,\n",
    ")\n",
    "cb = plt.colorbar(sc, ax=ax)\n",
    "cb.set_label(\"% provisórios\")\n",
    "ax.axhline(1.0, color=\"gray\", linestyle=\":\")\n",
    "ax.set_xlabel(\"Taxa de entrada (inclusões / população)\")\n",
    "ax.set_ylabel(\"Taxa de superlotação\")\n",
    "ax.set_title(\"Pergunta 3 — Entrada × superlotação (cor = % provisórios)\")\n",
    "fig.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "top_press = df.nlargest(20, \"indice_pressao_sistema\")[\n",
    "    [\n",
    "        \"uf\",\n",
    "        \"municipio\",\n",
    "        \"tipo_estabelecimento\",\n",
    "        \"indice_pressao_sistema\",\n",
    "        \"taxa_entrada\",\n",
    "        \"taxa_superlotacao_real\",\n",
    "        \"perc_provisorios\",\n",
    "        \"saldo_fluxo\",\n",
    "        \"pop_total_final\",\n",
    "    ]\n",
    "]\n",
    "display(Markdown(\"**20 estabelecimentos com maior índice de pressão sistêmica (proxy):**\"))\n",
    "display(\n",
    "    top_press.round(\n",
    "        {\n",
    "            \"indice_pressao_sistema\": 3,\n",
    "            \"taxa_entrada\": 4,\n",
    "            \"taxa_superlotacao_real\": 3,\n",
    "            \"perc_provisorios\": 3,\n",
    "            \"saldo_fluxo\": 0,\n",
    "            \"pop_total_final\": 0,\n",
    "        }\n",
    "    )\n",
    ")\n"
   ]
