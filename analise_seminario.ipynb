    "OUT_CSV = ROOT / \"dataset_indicadores_analiticos.csv\"\n",
    "df.to_csv(OUT_CSV, sep=\";\", index=False, encoding=\"utf-8\")\n",
    "display(Markdown(f\"Arquivo salvo: `{OUT_CSV}`\"))\n",
    "\n",
    "resumo_uf = (\n",
    "    df.groupby(\"uf\", observed=True)\n",
    "    .agg(\n",
    "        n_unidades=(\"uf\", \"size\"),\n",
    "        pop_total=(\"pop_total_final\", \"sum\"),\n",
    "        cap_total=(\"capacidade_total_final\", \"sum\"),\n",
    "        taxa_med=(\"taxa_superlotacao_real\", \"mean\"),\n",
    "        taxa_mediana=(\"taxa_superlotacao_real\", \"median\"),\n",
    "        pct_super=(\"flag_superlotacao\", \"mean\"),\n",
    "        media_prec=(\"indice_precariedade_estrutura\", \"mean\"),\n",
    "        media_press=(\"indice_pressao_sistema\", \"mean\"),\n",
    "    )\n",
    "    .sort_values(\"taxa_mediana\", ascending=False)\n",
    ")\n",
    "resumo_path = ROOT / \"outputs\" / \"resumo_por_uf.csv\"\n",
    "resumo_path.parent.mkdir(parents=True, exist_ok=True)\n",
    "resumo_uf.to_csv(resumo_path, sep=\";\", encoding=\"utf-8\")\n",
    "display(Markdown(\"**Resumo por UF (pré-visualização):**\"))\n",
    "_r = resumo_uf.head(12).copy()\n",
    "_r[\"pct_super\"] = _r[\"pct_super\"] * 100\n",
    "display(\n",
    "    _r.round(\n",
    "        {\n",
    "            \"pop_total\": 0,\n",
    "            \"cap_total\": 0,\n",
    "            \"taxa_med\": 3,\n",
    "            \"taxa_mediana\": 3,\n",
    "            \"pct_super\": 1,\n",
    "            \"media_prec\": 2,\n",
    "            \"media_press\": 3,\n",
    "            \"n_unidades\": 0,\n",
    "        }\n",
    "    )\n",
    ")\n",
    "display(Markdown(f\"CSV salvo: `{resumo_path}`\"))\n"
