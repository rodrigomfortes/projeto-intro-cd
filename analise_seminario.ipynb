    "def norm_name(s: str) -> str:\n",
    "    s = unicodedata.normalize(\"NFKD\", str(s))\n",
    "    s = \"\".join(ch for ch in s if not unicodedata.combining(ch))\n",
    "    return s.lower().strip()\n",
    "\n",
    "\n",
    "def pick_col(columns: list[str], includes: list[str], excludes: list[str] | None = None) -> str | None:\n",
    "    excludes = excludes or []\n",
    "    for col in columns:\n",
    "        nc = norm_name(col)\n",
    "        if all(term in nc for term in includes) and not any(term in nc for term in excludes):\n",
    "            return col\n",
    "    return None\n",
    "\n",
    "\n",
    "def to_num(s: pd.Series) -> pd.Series:\n",
    "    return pd.to_numeric(s, errors=\"coerce\")\n",
    "\n",
    "\n",
    "def sim_nao_to_binary(series: pd.Series) -> pd.Series:\n",
    "    def m(x):\n",
    "        if pd.isna(x) or str(x).strip() == \"\":\n",
    "            return np.nan\n",
    "        t = norm_name(str(x))\n",
    "        if t in (\"sim\", \"s\", \"yes\", \"true\", \"1\"):\n",
    "            return 1\n",
    "        if t in (\"nao\", \"não\", \"n\", \"no\", \"false\", \"0\"):\n",
    "            return 0\n",
    "        return np.nan\n",
    "\n",
    "    return series.map(m)\n",
    "\n",
    "\n",
    "for req in (\"pop_total_final\", \"capacidade_total_final\"):\n",
    "    if req not in df.columns:\n",
    "        raise KeyError(f\"Coluna esperada ausente no dataset v3: {req}\")\n",
    "\n",
    "pop = to_num(df[\"pop_total_final\"])\n",
    "cap = to_num(df[\"capacidade_total_final\"])\n",
    "\n",
    "if \"taxa_ocupacao\" in df.columns:\n",
    "    df[\"taxa_superlotacao_real\"] = to_num(df[\"taxa_ocupacao\"])\n",
    "else:\n",
    "    df[\"taxa_superlotacao_real\"] = np.where(cap.fillna(0) > 0, pop / cap, np.nan)\n",
    "\n",
    "df[\"deficit_vagas\"] = pop - cap\n",
    "df[\"flag_superlotacao\"] = np.where(df[\"taxa_superlotacao_real\"] > 1, 1, 0)\n",
    "\n",
    "if \"flag_sem_modulo_educacao\" in df.columns:\n",
    "    df[\"flag_sem_educacao\"] = to_num(df[\"flag_sem_modulo_educacao\"])\n",
    "elif \"educacao_nao_possui\" in df.columns:\n",
    "    df[\"flag_sem_educacao\"] = sim_nao_to_binary(df[\"educacao_nao_possui\"])\n",
    "else:\n",
    "    df[\"flag_sem_educacao\"] = np.nan\n",
    "\n",
    "if \"flag_sem_modulo_saude\" in df.columns:\n",
    "    df[\"flag_sem_saude\"] = to_num(df[\"flag_sem_modulo_saude\"])\n",
    "elif \"saude_nao_possui\" in df.columns:\n",
    "    df[\"flag_sem_saude\"] = sim_nao_to_binary(df[\"saude_nao_possui\"])\n",
    "else:\n",
    "    df[\"flag_sem_saude\"] = np.nan\n",
    "\n",
    "\n",
    "def _sem_assist_row(row) -> float:\n",
    "    if \"assist_juridica_nao\" in df.columns:\n",
    "        v = row.get(\"assist_juridica_nao\")\n",
    "        if pd.notna(v) and norm_name(v) == \"sim\":\n",
    "            return 1.0\n",
    "    vias = [\"assist_juridica_defensoria\", \"assist_juridica_dativos\", \"assist_juridica_ong\"]\n",
    "    vals = []\n",
    "    for c in vias:\n",
    "        if c not in df.columns:\n",
    "            continue\n",
    "        x = row.get(c)\n",
    "        if pd.isna(x) or str(x).strip() == \"\":\n",
    "            vals.append(np.nan)\n",
    "        elif norm_name(x) == \"sim\":\n",
    "            return 0.0\n",
    "        else:\n",
    "            vals.append(0.0)\n",
    "    if any(pd.notna(v) for v in vals):\n",
    "        return 1.0\n",
    "    return np.nan\n",
    "\n",
    "\n",
    "if any(\n",
    "    c in df.columns\n",
    "    for c in [\"assist_juridica_nao\", \"assist_juridica_defensoria\", \"assist_juridica_dativos\", \"assist_juridica_ong\"]\n",
    "):\n",
    "    df[\"flag_sem_assistencia_juridica\"] = df.apply(_sem_assist_row, axis=1)\n",
    "else:\n",
    "    df[\"flag_sem_assistencia_juridica\"] = np.nan\n",
    "\n",
    "parts_flags = df[[\"flag_sem_educacao\", \"flag_sem_saude\", \"flag_sem_assistencia_juridica\"]]\n",
    "df[\"indice_precariedade_estrutura\"] = parts_flags.sum(axis=1, min_count=1)\n",
    "\n",
    "mov_e = to_num(df[\"mov_entradas_total\"]) if \"mov_entradas_total\" in df.columns else pd.Series(np.nan, index=df.index)\n",
    "mov_a = to_num(df[\"mov_alvaras_total\"]) if \"mov_alvaras_total\" in df.columns else pd.Series(np.nan, index=df.index)\n",
    "df[\"taxa_entrada\"] = np.where(pop.fillna(0) > 0, mov_e / pop, np.nan)\n",
    "df[\"taxa_saida\"] = np.where(pop.fillna(0) > 0, mov_a / pop, np.nan)\n",
    "df[\"saldo_fluxo\"] = mov_e - mov_a\n",
    "\n",
    "\n",
    "def zscore(s: pd.Series) -> pd.Series:\n",
    "    s = pd.to_numeric(s, errors=\"coerce\")\n",
    "    mu = np.nanmean(s)\n",
    "    sd = np.nanstd(s)\n",
    "    if sd == 0 or np.isnan(sd):\n",
    "        return pd.Series(0.0, index=s.index)\n",
    "    return (s - mu) / sd\n",
    "\n",
    "\n",
    "excesso_lot = (df[\"taxa_superlotacao_real\"] - 1.0).clip(lower=0)\n",
    "perc_prov = to_num(df[\"perc_provisorios\"]) if \"perc_provisorios\" in df.columns else pd.Series(np.nan, index=df.index)\n",
    "z1 = zscore(df[\"taxa_entrada\"])\n",
    "z2 = zscore(excesso_lot)\n",
    "z3 = zscore(perc_prov)\n",
    "df[\"indice_pressao_sistema\"] = np.nanmean(np.vstack([z1.values, z2.values, z3.values]), axis=0)\n",
    "\n",
    "if \"civil_solteiro_total\" in df.columns:\n",
    "    df[\"perc_solteiro\"] = np.where(pop.fillna(0) > 0, to_num(df[\"civil_solteiro_total\"]) / pop, np.nan)\n",
    "else:\n",
    "    df[\"perc_solteiro\"] = np.nan\n",
    "\n",
    "if all(c in df.columns for c in [\"proc_urb_interior_total\", \"proc_urb_rm_total\", \"proc_rural_total\"]):\n",
    "    s = to_num(df[\"proc_urb_interior_total\"]) + to_num(df[\"proc_urb_rm_total\"]) + to_num(df[\"proc_rural_total\"])\n",
    "    df[\"perc_procedencia_urb_interior\"] = np.where(s.fillna(0) > 0, to_num(df[\"proc_urb_interior_total\"]) / s, np.nan)\n",
    "    df[\"perc_procedencia_urb_rm\"] = np.where(s.fillna(0) > 0, to_num(df[\"proc_urb_rm_total\"]) / s, np.nan)\n",
    "    df[\"perc_procedencia_rural\"] = np.where(s.fillna(0) > 0, to_num(df[\"proc_rural_total\"]) / s, np.nan)\n",
    "else:\n",
    "    df[\"perc_procedencia_urb_interior\"] = np.nan\n",
    "    df[\"perc_procedencia_urb_rm\"] = np.nan\n",
    "    df[\"perc_procedencia_rural\"] = np.nan\n",
    "\n",
    "for c in [\"controle_mais_90_dias\", \"controle_semiaberto_aguardando_vaga\"]:\n",
    "    if c in df.columns:\n",
    "        df[f\"flag_txt_{c}\"] = df[c].astype(str).str.strip().str.lower().str.startswith(\"sim\")\n",
    "\n",
    "display(Markdown(\"**Indicadores derivados calculados.** Trecho do quadro analítico:\"))\n",
    "cols_show = [\n",
    "    \"uf\",\n",
    "    \"municipio\",\n",
    "    \"taxa_superlotacao_real\",\n",
    "    \"deficit_vagas\",\n",
    "    \"indice_precariedade_estrutura\",\n",
    "    \"taxa_entrada\",\n",
    "    \"indice_pressao_sistema\",\n",
    "]\n",
    "cols_show = [c for c in cols_show if c in df.columns]\n",
    "_num = [c for c in cols_show if c not in (\"uf\", \"municipio\")]\n",
    "_preview = df[cols_show].head(10).copy()\n",
    "_preview[_num] = _preview[_num].apply(pd.to_numeric, errors=\"coerce\").round(4)\n",
    "display(_preview)\n"
   ]
  },
